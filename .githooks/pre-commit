#!/usr/bin/env bash
max_size=5368709120
failed=0

while IFS= read -r -d '' path; do
    size=$(git cat-file -s ":$path" 2>/dev/null || echo 0)
    if [ "$size" -gt "$max_size" ]; then
        echo "Blocked commit: $path is larger than 5 GB."
        failed=1
    fi
done < <(git diff --cached --name-only -z --diff-filter=ACMR)

exit "$failed"
